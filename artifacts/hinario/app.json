{
  "expo": {
    "name": "Hinário",
    "slug": "hinario",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "hinario",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#1d3557"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.miqueiasrezende1211cyber.hinario"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      "expo-web-browser"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "59eca185-10bd-4706-93fe-f8de89079c65"
      }
    }
  }
}
