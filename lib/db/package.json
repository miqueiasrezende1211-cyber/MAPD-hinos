{
  "name": "@workspace/db",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts"
  },
  "scripts": {
    "push": "node --env-file=../../.env ./scripts/run-drizzle-kit.mjs push --config ./drizzle.config.ts",
    "push-force": "node --env-file=../../.env ./scripts/run-drizzle-kit.mjs push --force --config ./drizzle.config.ts",
    "seed:hinos": "node --env-file=../../.env ./scripts/load-hinos.mjs",
    "seed:admin": "node --env-file=../../.env ./scripts/seed-admin.mjs"
  },
  "dependencies": {
    "drizzle-orm": "catalog:",
    "drizzle-zod": "^0.8.3",
    "pg": "^8.20.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.9"
  }
}
